# Copy this file to `.env` in the project root (same folder as package.json):
#   cp .env.example .env
#
# Prisma CLI (`migrate`, `db push`, etc.) only reads `.env`, not `.env.example`.
# Put your real Postgres URL below (Neon dashboard → Connection string → pooled).

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Vercel only: if you use Vercel Postgres, you can rely on POSTGRES_PRISMA_URL instead (set by the integration).
# POSTGRES_PRISMA_URL=

# Then run:
#   npx prisma migrate deploy
#   npm run dev
#
# Vercel: add DATABASE_URL under Project → Settings → Environment Variables.
# Build command: npm run vercel:build — see VERCEL.md
